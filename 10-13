<!DOCTYPE html>
<html>
<head>
    <title>Document Object Model</title>
    <script>
    window.onload = function () { 
        let clock = document.getElementById('clock'); 
        setInterval(function () { 
            let now = new Date(); 
            clock.innerHTML = now.toString(); 
            }, 1000); 
}; 

    
    </script>
</head>
<body>
    <h1 id="clock"></h1>
</body>
</html>
