// 11-15.jqEvent_hover.html
<!DOCTYPE html>
<html>
<head>
    <title>jQuery Basic</title>
    <script src="https://code.jquery.com/jquery-3.6.4.js"></script> 
    <script> 
        $(document).ready(function () { 
            $('h1').hover(function () { 
                $(this).css({ 
                    background: 'red', 
                    color: 'white' 
                }); 
            });
        });
    </script>
</head>
<body>
    <h1>Click</h1>
</body>
</html>
